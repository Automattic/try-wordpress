{
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"lib": [
			"DOM",
			"DOM.Iterable",
			"ESNext"
		],
		"allowJs": false,
		"skipLibCheck": true,
		"esModuleInterop": false,
		"allowSyntheticDefaultImports": true,
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"moduleResolution": "Node",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"paths": {
			"@schema/*": ["./schema/*"],
			"@/*": ["./src/*"]
		}
	},
	"include": [
		"src",
		"schema/schema.json"
	],
	"exclude": [
		"src/entrypoints",
		"src/app.config.ts"
	]
}
